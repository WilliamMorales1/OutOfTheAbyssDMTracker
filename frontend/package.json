{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build": "tsc && npx @tailwindcss/cli -i src/input.css -o dist/index.css --minify && node -e \"require('fs').cpSync('index.html','dist/index.html')\"",
    "watch:ts": "tsc --watch",
    "watch:css": "npx @tailwindcss/cli -i src/input.css -o dist/index.css --watch"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.2",
    "@types/marked": "^5.0.2",
    "tailwindcss": "^4.3.2",
    "typescript": "~6.0.2"
  },
  "dependencies": {
    "marked": "^4.3.0"
  }
}
